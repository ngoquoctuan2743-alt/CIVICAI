# Chuẩn hóa line ending — tránh xung đột CRLF/LF giữa Windows và Linux
* text=auto eol=lf

# Windows scripts giữ CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# File nhị phân — không xử lý text
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.zip binary
