# ==================================================
# VAIC 2026 - Biến môi trường mẫu (dùng cho `docker compose up`)
# Sao chép thành .env (docker compose tự đọc) hoặc dùng:
#   docker compose --env-file .env.development up -d --build
# Xem thêm mẫu sẵn dùng được ngay: .env.development (dev/demo) và
# .env.production (khung production — phải điền giá trị thật trước khi dùng).
# KHÔNG commit file .env chứa secret thật (đã bị .gitignore chặn).
# ==================================================

NODE_ENV=development

# ---- Database (PostgreSQL 16 + pgvector, container postgres) ----
DB_USER=vaic
DB_PASSWORD=vaic_dev_password
DB_NAME=vaic

# ---- Backend / JWT ----
# BẮT BUỘC đổi ở production, tối thiểu 32 ký tự ngẫu nhiên
JWT_SECRET=vaic-dev-secret-change-me
LOG_LEVEL=debug
# Origin Frontend được phép gọi API (CORS) — domain thật ở production, không dùng localhost
CORS_ORIGINS=http://localhost:3001

# ---- AI Service / LLM ----
# mock: không cần API key, trả lời giả lập nhưng RAG search vẫn dùng embedding thật
# claude: cần điền ANTHROPIC_API_KEY thật bên dưới
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# ---- Frontend (build-time, inline vào bundle khi docker build) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:3100/api/v1
