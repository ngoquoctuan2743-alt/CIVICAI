# ==================================================
# VAIC 2026 Backend - Biến môi trường mẫu
# Sao chép thành .env và điền giá trị thật.
# KHÔNG commit file .env.
# ==================================================

# ---- App ----
# Môi trường chạy: development | test | staging | production
NODE_ENV=development
# Cổng HTTP của backend
PORT=3100
# Prefix chung cho mọi route API
API_PREFIX=api/v1
# Phiên bản ứng dụng (hiển thị ở endpoint /version)
APP_VERSION=0.1.0
# Origin Frontend được phép gọi API (CORS), phân tách bởi dấu phẩy
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3000

# ---- Authentication (JWT) ----
# BẮT BUỘC đổi ở production; dev có thể để trống (dùng mặc định)
JWT_SECRET=vaic-dev-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# ---- Database (PostgreSQL + pgvector qua docker-compose ở thư mục gốc) ----
DB_HOST=localhost
DB_PORT=5433
DB_USER=vaic
DB_PASSWORD=vaic_dev_password
DB_NAME=vaic
# Bật log SQL của TypeORM khi cần debug: true | false
DB_LOGGING=false

# ---- Logging ----
# Mức log: error | warn | log | debug | verbose
LOG_LEVEL=debug

# ---- AI Service (PHASE 4 — System Integration) ----
# Container ai-service chạy ngoài docker network: dùng localhost:8000
# Backend cũng chạy trong docker-compose: dùng http://ai-service:8000
AI_SERVICE_BASE_URL=http://localhost:8000
AI_CHAT_TIMEOUT_MS=20000
AI_DOCUMENT_TIMEOUT_MS=25000
AI_SEARCH_TIMEOUT_MS=8000
AI_CIRCUIT_BREAKER_THRESHOLD=5
AI_CIRCUIT_BREAKER_RESET_MS=30000

# ---- Storage (upload OCR, local disk demo) ----
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_BYTES=8388608

# ---- Embedding Pipeline (PROMPT 04) ----
# Provider: gemini | openai | voyage | jina | bge | local (chỉ gemini có adapter thật)
EMBEDDING_PROVIDER=gemini
# BẮT BUỘC khi EMBEDDING_PROVIDER=gemini — lấy tại https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=768
EMBEDDING_BATCH_SIZE=20
EMBEDDING_MAX_CONCURRENCY=2
EMBEDDING_RATE_LIMIT_PER_MINUTE=60
EMBEDDING_MAX_ATTEMPTS=3
