.PHONY: help setup dev build test lint clean

help: ## Liệt kê các lệnh khả dụng
	@echo "CIVICAI - cac lenh se duoc bo sung theo tung module:"
	@echo "  make setup  - Cai dat dependencies (chua cai dat)"
	@echo "  make dev    - Chay moi truong dev (chua cai dat)"
	@echo "  make build  - Build toan bo du an (chua cai dat)"
	@echo "  make test   - Chay test (chua cai dat)"
	@echo "  make lint   - Kiem tra code style (chua cai dat)"
	@echo "  make clean  - Don dep build artifacts (chua cai dat)"

setup:
	@echo "[PLACEHOLDER] setup: chua duoc cai dat"

dev:
	@echo "[PLACEHOLDER] dev: chua duoc cai dat"

build:
	@echo "[PLACEHOLDER] build: chua duoc cai dat"

test:
	@echo "[PLACEHOLDER] test: chua duoc cai dat"

lint:
	@echo "[PLACEHOLDER] lint: chua duoc cai dat"

clean:
	@echo "[PLACEHOLDER] clean: chua duoc cai dat"
