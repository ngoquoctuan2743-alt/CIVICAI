# ==================================================
# VAIC 2026 - Biến môi trường DEVELOPMENT (dùng cho `docker compose up`)
# Sao chép thành .env nếu muốn compose tự động đọc, hoặc dùng:
#   docker compose --env-file .env.development up -d --build
# Giá trị ở đây là mặc định AN TOÀN cho dev/demo — KHÔNG dùng cho production.
# ==================================================

NODE_ENV=development

# ---- Database ----
DB_USER=vaic
DB_PASSWORD=vaic_dev_password
DB_NAME=vaic

# ---- Backend / JWT ----
JWT_SECRET=vaic-dev-secret-change-me
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:3001

# ---- AI Service / LLM ----
# mock: không cần API key, trả lời giả lập nhưng RAG search vẫn dùng embedding thật
# claude: cần điền ANTHROPIC_API_KEY thật bên dưới
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# ---- Frontend (build-time, inline vào bundle) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:3100/api/v1
