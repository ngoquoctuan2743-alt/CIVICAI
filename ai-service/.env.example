# ==================================================
# VAIC AI Service - Biến môi trường
# Sao chép thành .env và điền giá trị thật. KHÔNG commit .env.
# ==================================================

ENVIRONMENT=development

# ---- LLM ----
# Provider: claude | mock (openai/gemini/local: chưa có adapter)
LLM_PROVIDER=claude
# BẮT BUỘC khi LLM_PROVIDER=claude — lấy tại https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# ---- Embedding ----
EMBEDDING_PROVIDER=e5
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# ---- Voice: browser (Web Speech API ở client) ----
VOICE_ENGINE=browser

# ---- Database (PostgreSQL dùng chung với backend) ----
# Chạy local: localhost:5433 | chạy trong docker network: postgres:5432
DB_HOST=localhost
DB_PORT=5433
DB_USER=vaic
DB_PASSWORD=vaic_dev_password
DB_NAME=vaic

# ---- Backend (proxy /ai/history) ----
BACKEND_BASE_URL=http://localhost:3100/api/v1
