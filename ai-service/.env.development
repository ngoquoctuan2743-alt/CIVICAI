# ==================================================
# VAIC AI Service - DEVELOPMENT (chạy trực tiếp hoặc container ngoài docker-compose)
# Sao chép thành .env. Mặc định LLM_PROVIDER=mock để chạy demo không cần API key.
# ==================================================

ENVIRONMENT=development

LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_TIMEOUT_MS=30000
GEMINI_MAX_RETRIES=3
GEMINI_TEMPERATURE=0.7
GEMINI_TOP_P=0.95
GEMINI_TOP_K=40

EMBEDDING_PROVIDER=e5
EMBEDDING_MODEL=intfloat/multilingual-e5-small

VOICE_ENGINE=browser

DB_HOST=localhost
DB_PORT=5433
DB_USER=vaic
DB_PASSWORD=vaic_dev_password
DB_NAME=vaic

BACKEND_BASE_URL=http://localhost:3100/api/v1
