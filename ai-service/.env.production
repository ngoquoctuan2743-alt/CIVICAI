# ==================================================
# VAIC AI Service - PRODUCTION (mẫu — CHỈ chứa placeholder)
# Sao chép thành .env, thay TOÀN BỘ giá trị <...> bằng giá trị thật.
# ==================================================

ENVIRONMENT=production

LLM_PROVIDER=claude
ANTHROPIC_API_KEY=<dien-anthropic-api-key-that>
CLAUDE_MODEL=claude-opus-4-8

GEMINI_API_KEY=<dien-gemini-api-key-that-neu-dung-LLM_PROVIDER=gemini>
GEMINI_MODEL=gemini-flash-latest
GEMINI_TIMEOUT_MS=30000
GEMINI_MAX_RETRIES=3
GEMINI_TEMPERATURE=0.7
GEMINI_TOP_P=0.95
GEMINI_TOP_K=40

EMBEDDING_PROVIDER=e5
EMBEDDING_MODEL=intfloat/multilingual-e5-small

VOICE_ENGINE=browser

DB_HOST=<host-postgres-production>
DB_PORT=5432
DB_USER=vaic
DB_PASSWORD=<doi-mat-khau-production-that>
DB_NAME=vaic

BACKEND_BASE_URL=<http://backend-production-host:3100/api/v1>
