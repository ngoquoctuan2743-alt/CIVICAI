# ==================================================
# VAIC 2026 - Biến môi trường PRODUCTION (mẫu — CHỈ chứa placeholder)
# Sao chép thành .env, thay TOÀN BỘ giá trị <...> bằng giá trị thật.
# KHÔNG commit file .env thật chứa secret thật (đã bị .gitignore chặn).
# ==================================================

NODE_ENV=production

# ---- Database ----
DB_USER=vaic
DB_PASSWORD=<doi-mat-khau-production-that>
DB_NAME=vaic

# ---- Backend / JWT ----
# BẮT BUỘC: đổi khác giá trị dev, tối thiểu 32 ký tự ngẫu nhiên
JWT_SECRET=<doi-jwt-secret-production-that>
LOG_LEVEL=log
# Domain thật của frontend production (không dùng localhost)
CORS_ORIGINS=<https://domain-frontend-that.example.com>

# ---- AI Service / LLM ----
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=<dien-anthropic-api-key-that>
CLAUDE_MODEL=claude-opus-4-8

# ---- Frontend (build-time, inline vào bundle) ----
NEXT_PUBLIC_API_BASE_URL=<https://domain-backend-that.example.com/api/v1>
